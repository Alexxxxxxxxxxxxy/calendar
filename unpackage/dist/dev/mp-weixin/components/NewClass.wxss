/* 微信小程序适配 - 遮罩层 */
.modal-overlay.data-v-fb8db99d {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 微信小程序专用模态框渐变背景 */
.modal-bg.data-v-fb8db99d {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.9) 0%, rgba(118, 75, 162, 0.9) 100%);
  z-index: -1;
}
.main.data-v-fb8db99d {
  width: 100%;
  max-width: 750rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* 毛玻璃卡片 - 小程序兼容 */
.glass-card.data-v-fb8db99d {
  background: white;
  border: 1px solid rgba(102, 126, 234, 0.2);
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  padding: 40rpx;
  position: relative;
  box-sizing: border-box;
}

/* 关闭按钮通用样式 */
.close-btn.data-v-fb8db99d {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 50%;
  transition: all 0.3s ease;
  z-index: 10;
}
.close-btn.data-v-fb8db99d:active {
  background: rgba(102, 126, 234, 0.2);
  transform: scale(0.9);
}
.close-btn .close-icon.data-v-fb8db99d {
  font-size: 32rpx;
  color: #667eea;
  font-weight: 500;
}

/* 返回按钮 - 左侧定位 */
.back-btn.data-v-fb8db99d {
  right: auto;
  left: 30rpx;
}
.form-title.data-v-fb8db99d {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 40rpx;
  text-align: center;
}
.form-group.data-v-fb8db99d {
  margin-bottom: 30rpx;
}
.form-group.data-v-fb8db99d:last-child {
  margin-bottom: 0;
}
.form-label.data-v-fb8db99d {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 15rpx;
}

/* 修复微信小程序placeholder上移问题 - 仅修改此处 */
