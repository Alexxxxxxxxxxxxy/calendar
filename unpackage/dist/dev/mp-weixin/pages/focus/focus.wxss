/* 微信小程序兼容背景 - 三重保障 */
page.data-v-e6ed2a79 {
  width: 100%;
  height: 100%;
  min-height: 100vh;
  background-color: #667eea;
  /* 纯色兜底 */
  margin: 0;
  padding: 0;
}
.page-container.data-v-e6ed2a79 {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);
  /* 兼容小程序渐变 */
}
.container.data-v-e6ed2a79 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 微信小程序兼容的毛玻璃卡片 */
.glass-card.data-v-e6ed2a79 {
  background: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  position: relative;
  z-index: 1;
}

