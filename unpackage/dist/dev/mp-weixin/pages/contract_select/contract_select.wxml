<view class="page-container data-v-87e990da"><view class="bg-layer data-v-87e990da"></view><view class="navbar data-v-87e990da"><view class="back-btn data-v-87e990da" bindtap="{{a}}"><text class="back-text data-v-87e990da">← 返回</text></view><view class="title-box data-v-87e990da"><text class="title data-v-87e990da">📝 合约选择</text></view></view><view class="segment-control glass-card data-v-87e990da"><view wx:for="{{b}}" wx:for-item="day" wx:key="b" class="{{['seg-item', 'data-v-87e990da', day.c && 'active']}}" bindtap="{{day.d}}"><text class="data-v-87e990da">{{day.a}}</text></view></view><view class="info-card glass-card data-v-87e990da"><view class="info-row data-v-87e990da"><text class="label data-v-87e990da">合约总学习时长：</text><text class="value data-v-87e990da">{{c}} 小时</text></view><view class="info-row data-v-87e990da"><text class="label data-v-87e990da">每日学习时长范围：</text><text class="value data-v-87e990da">{{d}}</text></view></view><view class="recommend-box glass-card data-v-87e990da"><text class="rec-label data-v-87e990da">根据考试日期系统推荐：</text><text class="rec-value data-v-87e990da">{{e}}天</text></view><view class="plan-section glass-card data-v-87e990da"><view class="plan-item main-plan data-v-87e990da"><text class="data-v-87e990da">普通计划</text></view><text class="section-title data-v-87e990da">✨ 会员专享</text><view class="vip-list data-v-87e990da"><view wx:for="{{f}}" wx:for-item="plan" wx:key="b" class="vip-item data-v-87e990da"><text class="data-v-87e990da">{{plan.a}}</text><view class="arrow-icon data-v-87e990da">→</view></view></view></view><view class="footer-action data-v-87e990da"><view class="input-group glass-card data-v-87e990da"><text class="input-label data-v-87e990da">请输入首日学习时长：</text><input type="number" placeholder="例如：2.5" class="custom-input data-v-87e990da" value="{{g}}" bindinput="{{h}}"/></view><view class="submit-btn data-v-87e990da" bindtap="{{i}}"><text class="btn-text data-v-87e990da">创建合约</text></view></view></view>