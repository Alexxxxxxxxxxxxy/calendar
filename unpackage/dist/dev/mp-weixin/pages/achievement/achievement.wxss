/* 空状态 - 通用 */
.empty-state.data-v-127b3c96 {
  grid-column: 1/-1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  padding: 100rpx 40rpx;
}
.empty-state .empty-icon.data-v-127b3c96 {
  font-size: 120rpx;
  opacity: 0.7;
  animation: float-127b3c96 3s ease-in-out infinite;
  /* 浮动动画 */
}
.empty-state .empty-text.data-v-127b3c96 {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}
.empty-state .empty-subtext.data-v-127b3c96 {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

/* 成就空状态 */
.achievement-empty .empty-icon.data-v-127b3c96 {
  animation-delay: 0s;
}

/* 荣誉空状态 */
.honor-empty .empty-icon.data-v-127b3c96 {
  animation-delay: 0.5s;
}

/* 浮动动画关键帧 */
@keyframes float-127b3c96 {
0%, 100% {
    transform: translateY(0);
}
50% {
    transform: translateY(-20rpx);
}
}