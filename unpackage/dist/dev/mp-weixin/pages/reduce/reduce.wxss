/* 微信小程序 page 适配 */
page.data-v-ef914764 {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  background-color: #667eea;
}

/* 固定渐变背景层（小程序兼容核心） */
.bg-layer.data-v-ef914764 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  z-index: -1;
}

/* 全局容器 */
.page-container.data-v-ef914764 {
  padding: 20rpx 40rpx;
  min-height: 100vh;
  position: relative;
  z-index: 1;
}

/* 毛玻璃卡片样式 */
.glass-card.data-v-ef914764 {
  background: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

/* 顶部标题 */
.header.data-v-ef914764 {
  background: rgba(255, 255, 255, 0.25);
  padding: 24rpx;
  border-radius: 30rpx;
  text-align: center;
  margin-bottom: 40rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
}
.header-text.data-v-ef914764 {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 任务卡片 */
.category-card.data-v-ef914764 {
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.category-header.data-v-ef914764 {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.category-title.data-v-ef914764 {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-left: 10rpx;
  margin-right: auto;
}

/* 总时长胶囊标签 */
.total-tag.data-v-ef914764 {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* 子任务项 */
.sub-task-item.data-v-ef914764 {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
  padding: 20rpx 0;
  text-align: center;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
  /* 选中状态样式 */
}
.sub-task-item.active.data-v-ef914764 {
  background: #ffffff;
  color: #667eea;
  font-weight: bold;
  transform: scale(0.98);
}
.sub-task-item.data-v-ef914764:active {
  transform: scale(0.95);
}

/* 底部面板 */
.bottom-panel.data-v-ef914764 {
  padding: 30rpx;
  margin-top: 20rpx;
}
.selected-header.data-v-ef914764 {
  background: rgba(255, 255, 255, 0.3);
  align-self: flex-start;
  padding: 10rpx 25rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}
.selected-text.data-v-ef914764 {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

/* 已选任务占位条 */
.selected-content.data-v-ef914764 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.selected-item-pill.data-v-ef914764 {
  background: rgba(255, 255, 255, 0.2);
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  padding-left: 30rpx;
}
.pill-text.data-v-ef914764 {
  color: #ffffff;
  font-size: 24rpx;
}
.empty-state.data-v-ef914764 {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-top: 10rpx;
}
.total-duration.data-v-ef914764 {
  margin-top: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 底部按钮 */
.footer-btn.data-v-ef914764 {
  margin-top: 60rpx;
  padding: 0 40rpx;
}

/* 小程序按钮样式优化 */
button.data-v-ef914764 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: #ffffff !important;
  border-radius: 40rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
}
button.data-v-ef914764:active {
  transform: scale(0.98);
}