/* ========================================
   微信小程序背景 - 三重保障方案
   ======================================== */
/* 第1重：page 标签 - 纯色兜底 */
page.data-v-9c3a1a54 {
  width: 100%;
  min-height: 100%;
  height: 100%;
  background-color: #667eea;
  margin: 0;
  padding: 0;
}

/* 第2重：page-container - 渐变背景（主要显示） */
.page-container.data-v-9c3a1a54 {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

/* 第3重：container - 再次确保背景 */
.container.data-v-9c3a1a54 {
  width: 100%;
  min-height: 100vh;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  background: transparent;
}

/* ========================================
   以下样式保持不变
   ======================================== */
/* 进度条区域 */
.progress-section.data-v-9c3a1a54 {
  margin-bottom: 40rpx;
}
.progress-section .section-title.data-v-9c3a1a54 {
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  width: 220rpx;
  height: 70rpx;
  border-radius: 100rpx;
  margin: 0 auto 30rpx auto;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}
.progress-section .progress-bar.data-v-9c3a1a54 {
  height: 20rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 10rpx;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.3);
}
.progress-section .progress-bar .progress-fill.data-v-9c3a1a54 {
  height: 100%;
  background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 10rpx;
  box-shadow: 0 0 12rpx rgba(79, 172, 254, 0.5);
}

/* 任务列表 */
.task-list.data-v-9c3a1a54 {
  max-height: 1000rpx;
  overflow-y: scroll;
}
.task-list .task-card.data-v-9c3a1a54 {
  background: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 36rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
.task-list .task-card.data-v-9c3a1a54:last-child {
  margin-bottom: 0;
}
.task-list .task-header.data-v-9c3a1a54 {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.task-list .task-header .checkbox.data-v-9c3a1a54 {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(246, 211, 101, 0.4);
}
.task-list .task-header .task-title.data-v-9c3a1a54 {
  font-size: 34rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.task-list .subtask-item.data-v-9c3a1a54 {
  width: 100%;
  min-height: 72rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 36rpx;
  margin-bottom: 18rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: white;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.task-list .subtask-item.data-v-9c3a1a54:last-child {
  margin-bottom: 0;
}

/* 统计区域 */
.stats-section.data-v-9c3a1a54 {
  margin-top: 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: white;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}