/* 微信小程序兼容背景 - 三重保障 */
page.data-v-25dadb5e {
  width: 100%;
  height: 100%;
  min-height: 100vh;
  background-color: #667eea;
  /* 纯色兜底，小程序必显示 */
  margin: 0;
  padding: 0;
}
.page-container.data-v-25dadb5e {
  width: 100%;
  min-height: 100vh;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  background: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);
  /* 兼容小程序渐变 */
}
.main.data-v-25dadb5e {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 50rpx;
  box-sizing: border-box;
}

/* 微信小程序兼容的毛玻璃卡片 */
.glass-card.data-v-25dadb5e {
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
}
.glass-card.data-v-25dadb5e:active {
  transform: scale(0.98);
}
.current-tab.data-v-25dadb5e {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.4);
}

/* 通用标签样式 */
.tag.data-v-25dadb5e {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  text-align: center;
  border-radius: 100rpx;
  padding: 16rpx 40rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
}
.other-tag.data-v-25dadb5e {
  background: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 通用卡片内容样式 */
.current.data-v-25dadb5e, .other.data-v-25dadb5e {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-sizing: border-box;
}
.tab.data-v-25dadb5e {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-sizing: border-box;
  padding: 40rpx 50rpx;
  justify-content: center;
  align-items: flex-start;
}
.type.data-v-25dadb5e {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(79, 172, 254, 0.3);
}
.time.data-v-25dadb5e {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}
.deposit.data-v-25dadb5e {
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(246, 211, 101, 0.35);
}