/* 微信小程序 page 适配 */
page.data-v-b32b1d96 {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  background-color: #667eea;
}

/* 固定渐变背景层（小程序兼容核心） */
.bg-layer.data-v-b32b1d96 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  z-index: -1;
}

/* 页面容器 */
.page-container.data-v-b32b1d96 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-top: 40rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* 毛玻璃卡片通用样式 */
.glass-card.data-v-b32b1d96 {
  background: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}
.glass-card.data-v-b32b1d96:active {
  transform: scale(0.98);
}

/* 顶部标题样式 */
.header.data-v-b32b1d96 {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}
.header-text.data-v-b32b1d96 {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  padding: 12rpx 40rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

/* 任务列表容器 */
.task-list.data-v-b32b1d96 {
  flex: 1;
  padding: 0 30rpx;
}

/* 任务卡片样式 */
.task-card.data-v-b32b1d96 {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 卡片头部布局 */
.card-header.data-v-b32b1d96 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}
.left-part.data-v-b32b1d96 {
  display: flex;
  align-items: center;
}
.title.data-v-b32b1d96 {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-left: 10rpx;
}

/* 右侧胶囊标签 */
.tag.data-v-b32b1d96 {
  background: rgba(255, 255, 255, 0.3);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}
.tag-text.data-v-b32b1d96 {
  font-size: 24rpx;
  color: #fff;
}

/* 子任务项 */
.sub-item.data-v-b32b1d96 {
  background: rgba(255, 255, 255, 0.2);
  height: 60rpx;
  border-radius: 30rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 30rpx;
  box-sizing: border-box;
}
.sub-text.data-v-b32b1d96 {
  font-size: 26rpx;
  color: #fff;
}

/* 底部按钮区域 */
.footer.data-v-b32b1d96 {
  padding: 40rpx 60rpx;
  background: transparent !important;
}
.confirm-btn.data-v-b32b1d96 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: #fff !important;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
  border: none;
}

/* 去除button默认边框 */
.confirm-btn.data-v-b32b1d96::after {
  border: none;
}