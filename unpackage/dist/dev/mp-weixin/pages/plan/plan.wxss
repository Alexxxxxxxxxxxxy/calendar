
/* 微信小程序 page 样式 */
page {
  width: 100%;
  min-height: 100%;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  margin: 0;
  padding: 0;
}
.page-container.data-v-bee4c29d {
  width: 100%;
  min-height: 100vh;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}
.content.data-v-bee4c29d {
  width: 100%;
}

/* 顶部状态区 */
.status-section.data-v-bee4c29d {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}
.status-tag.data-v-bee4c29d {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}
.streak-tag.data-v-bee4c29d {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 30rpx;
  color: white;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.3);
}

/* 通用卡片样式 */
.card.data-v-bee4c29d {
  background: rgba(255, 255, 255, 0.28);
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  position: relative;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.25);
}
.card-title.data-v-bee4c29d {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 70rpx;
  color: white;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}
.btn.data-v-bee4c29d {
  position: absolute;
  bottom: 40rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
  color: white;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(246, 211, 101, 0.35);
}

/* 任务区域 */
.section.data-v-bee4c29d {
  margin-bottom: 40rpx;
}
.section-title.data-v-bee4c29d {
  background: rgba(255, 255, 255, 0.25);
  display: inline-block;
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}
.task-card.data-v-bee4c29d {
  background: rgba(255, 255, 255, 0.28);
  border-radius: 36rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.25);
}
.task-header.data-v-bee4c29d {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.task-dot.data-v-bee4c29d {
  width: 28rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  border-radius: 50%;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(246, 211, 101, 0.4);
}
.task-name.data-v-bee4c29d {
  font-size: 34rpx;
  font-weight: bold;
  flex: 1;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.task-state.data-v-bee4c29d {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: white;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(79, 172, 254, 0.3);
}
.task-points.data-v-bee4c29d {
  margin-top: 12rpx;
}
.point.data-v-bee4c29d {
  background: rgba(255, 255, 255, 0.25);
  min-height: 72rpx;
  border-radius: 36rpx;
  margin-bottom: 18rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: white;
  line-height: 1.5;
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.point.data-v-bee4c29d:last-child {
  margin-bottom: 0;
}

/* 按钮容器 */
.btn-container.data-v-bee4c29d {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}
.submit-btn.data-v-bee4c29d {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx 80rpx;
  border-radius: 100rpx;
  font-size: 30rpx;
  color: white;
  font-weight: bold;
  border: 2px solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
}
